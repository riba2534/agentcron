# Claude Crontab · 环境变量样例
# 拷贝为 .env 后按需修改。

# ── packages/db ────────────────────────────────────────────────
# 用户机器最终值：file:~/.cct/db.sqlite
# 开发阶段使用包内 dev.db。注意：Prisma SQLite URL 中的相对路径
# 是相对于 schema.prisma 所在目录解析的（即 packages/db/prisma/）。
CCT_DB_URL=file:./dev.db

# ── apps/web ───────────────────────────────────────────────────
# JWT 签名 secret（auth.login 颁发的 cct_session cookie）
# 至少 32 字符，部署前请轮换
JWT_SECRET=replace-me-with-a-32-char-random-string-please

# ── apps/runner ────────────────────────────────────────────────
# launchd / crontab 调度器写入的 runner 二进制路径
# macOS 默认：/usr/local/bin/cct-runner
# Linux 默认：/usr/local/bin/cct-runner
CCT_RUNNER_BIN=/usr/local/bin/cct-runner

# 任务执行日志目录
# macOS: ~/Library/Logs/cct
# Linux: ~/.local/share/cct/logs
CCT_LOG_DIR=~/Library/Logs/cct

# 全局并发上限（默认 3）
CCT_MAX_CONCURRENT_RUNS=3

# claude CLI 路径（runner 调用任务时用）
# 默认 PATH 解析；显式覆盖更稳：
# CCT_CLAUDE_BIN=~/.local/bin/claude

# ── packages/secrets (Linux 兜底) ─────────────────────────────
# macOS 自动用 Keychain；Linux 走文件路径（0600）
# CCT_MASTER_KEY_PATH=~/.cct/master.key

# 强制使用文件主密钥（即使在 macOS）— CI / 测试场景避免动 Keychain
# CCT_FORCE_FILE_MASTERKEY=1
